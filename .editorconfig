; EditorConfig file per http://editorconfig.org/

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true

[*.go]
indent_style = tab
indent_size = 4

[*.{sh,zsh}]
indent_style = space
indent_size = 2
trim_trailing_whitespace = true

[*.py]
indent_style = space
indent_size = 4
trim_trailing_whitespace = true

[*.md]
indent_style = space
indent_size = 2
trim_trailing_whitespace = false

[*.{toml,yaml,yml}]
indent_style = space
indent_size = 2
trim_trailing_whitespace = true

[{Taskfile.yml,goreleaser.yaml}]
indent_style = space
indent_size = 2

[{Makefile,*.mk}]
indent_style = tab
indent_size = 8

[.git*]
indent_style = tab
indent_size = 8
